# Target repository for the digest, owner/name
REPO=aguilasa/css-windify

# How many days back to look for updated PRs/issues (optional, default 7)
DAYS=7

# Gmail account used to send the summary (SMTP + App Password)
EMAIL_FROM=your-address@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_TO=recipient@example.com
